{
  "$schema": "https://sympo.si/schemas/sym-app-v1.json",
  "schema_version": 1,
  "id": "jukebox",
  "name": "Jukebox",
  "description": "A shared VPS-hosted music library with private playback state in every browser.",
  "runtime": {
    "type": "python",
    "health_path": "/_sym/health",
    "startup_timeout_seconds": 60,
    "shutdown_timeout_seconds": 10
  },
  "configuration": {
    "environment": [],
    "secrets": []
  },
  "integrations": [],
  "agent": {
    "instructions_path": "AGENTS.md",
    "bootstrap_path": "/api/agent/bootstrap",
    "mcp_path": "/mcp"
  },
  "permissions": [],
  "data": {
    "persistent_paths": [".sym-data"],
    "user_data": {
      "enabled": true,
      "description": "Music, artwork, and playlists managed by the user or their agent.",
      "label": "Music library",
      "quota_mb": 51200,
      "content_types": ["audio/*", "image/jpeg", "image/png", "image/webp", "text/plain"],
      "directories": ["Music", "Playlists", "Artwork", "Jukebox API"]
    },
    "private_state": true,
    "cache": true,
    "legacy_persistent_migration": "user_data"
  },
  "marketplace": {
    "subtitle": "Your music library, streamed privately in each browser",
    "category": "content",
    "icon": "assets/icon.svg",
    "accent_color": "#7c3aed"
  }
}
